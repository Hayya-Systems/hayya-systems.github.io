---
interface Props {
  title: string;
  description: string;
  items?: string[];
  index?: number;
  i18nTitle?: string;
  i18nDesc?: string;
  i18nItems?: string;
}

const { title, description, items = [], index = 0, i18nTitle, i18nDesc, i18nItems } = Astro.props;

const iconPaths = [
  `<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="m9 14 2 2 4-4"/>`,
  `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><circle cx="10" cy="15" r="2"/><path d="m20 20-2.5-2.5"/>`,
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  `<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>`,
];

const icon = iconPaths[index % iconPaths.length];
---

<article class="service-card">
  <div class="service-card__head">
    <div class="service-card__icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <Fragment set:html={icon} />
      </svg>
    </div>
    <span class="service-card__num" aria-hidden="true">0{index + 1}</span>
  </div>

  <h3 class="service-card__title" data-i18n={i18nTitle}>{title}</h3>
  <p class="service-card__desc" data-i18n={i18nDesc}>{description}</p>

  {items.length > 0 && (
    <ul class="service-card__items" role="list" data-i18n-list={i18nItems}>
      {items.map((item, i) => (
        <li class="service-card__item" data-i18n-list-item>
          <span class="service-card__check" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          <span data-i18n-list-text>{item}</span>
        </li>
      ))}
    </ul>
  )}
</article>

<style>
  .service-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .service-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  }

  .service-card:hover {
    border-color: var(--color-neutral-200);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .service-card:hover::after { transform: scaleX(1); }

  .service-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .service-card__icon {
    width: 44px;
    height: 44px;
    background-color: rgba(200, 32, 43, 0.06);
    border: 1px solid rgba(200, 32, 43, 0.1);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .service-card__num {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-300);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }

  .service-card__title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-steel);
    line-height: var(--leading-snug);
    letter-spacing: -0.015em;
    margin: 0;
  }

  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  .service-card__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-4);
    margin-top: var(--space-1);
  }

  .service-card__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .service-card__check {
    width: 18px;
    height: 18px;
    background: rgba(200, 32, 43, 0.07);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
