---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/index';

const t = getTranslations('es');
---

<Layout title={t.contact.pageTitle} currentPath="/contacto">

  <section class="page-hero">
    <div class="container">
      <span class="page-hero__label" data-i18n="contact.pageLabel">{t.contact.pageLabel}</span>
      <h1 class="page-hero__title" data-i18n="contact.pageTitle">{t.contact.pageTitle}</h1>
      <p class="page-hero__lead" data-i18n="contact.pageLead">{t.contact.pageLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <aside class="contact-aside">
          <h2 class="contact-block__title" data-i18n="contact.directContact">{t.contact.directContact}</h2>
          <p class="contact-block__text" data-i18n="contact.directContactText">{t.contact.directContactText}</p>

          <a
            href={`mailto:${t.footer.email}`}
            class="contact-email-card"
            aria-label={`Enviar correo a ${t.footer.email}`}
          >
            <div class="contact-email-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div class="contact-email-card__content">
              <span class="contact-email-card__label">Correo electrónico</span>
              <span class="contact-email-card__value">{t.footer.email}</span>
            </div>
            <svg class="contact-email-card__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>

          <p class="contact-response-note">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            Respuesta en hasta 48 horas hábiles
          </p>

          <div class="contact-aside__divider"></div>

          <div class="contact-aside__note">
            <h3 class="contact-aside__note-title">Consultas habituales</h3>
            <ul class="contact-aside__topics" role="list">
              <li>Solicitudes de servicio o propuesta</li>
              <li>Información sobre áreas de práctica</li>
              <li>Perfiles profesionales y empleos</li>
              <li>Consultas generales sobre la firma</li>
            </ul>
          </div>
        </aside>

        <div class="contact-form-wrap">
          <h2 class="contact-block__title" data-i18n="contact.formTitle">{t.contact.formTitle}</h2>
          <p class="contact-block__text" data-i18n="contact.formNote">{t.contact.formNote}</p>

          <form id="contact-form" class="contact-form" novalidate>
            <div class="form-row">
              <div class="form-field">
                <label for="name" class="form-label" data-i18n="contact.fieldName">
                  {t.contact.fieldName}
                  <span class="form-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="form-input"
                  required
                  autocomplete="name"
                  placeholder="Su nombre completo"
                />
              </div>
              <div class="form-field">
                <label for="email" class="form-label" data-i18n="contact.fieldEmail">
                  {t.contact.fieldEmail}
                  <span class="form-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  required
                  autocomplete="email"
                  placeholder="correo@empresa.com"
                />
              </div>
            </div>

            <div class="form-field">
              <label for="org" class="form-label" data-i18n="contact.fieldOrg">{t.contact.fieldOrg}</label>
              <input
                type="text"
                id="org"
                name="org"
                class="form-input"
                autocomplete="organization"
                placeholder="Nombre de su organización"
              />
            </div>

            <div class="form-field">
              <label for="subject" class="form-label" data-i18n="contact.fieldSubject">
                {t.contact.fieldSubject}
                <span class="form-required" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="form-input"
                required
                placeholder="Motivo de contacto"
              />
            </div>

            <div class="form-field">
              <label for="message" class="form-label" data-i18n="contact.fieldMessage">
                {t.contact.fieldMessage}
                <span class="form-required" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                class="form-textarea"
                required
                rows="5"
                placeholder="Detalle su consulta o solicitud"
              ></textarea>
            </div>

            <div class="form-footer">
              <button type="submit" class="btn btn--primary form-submit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
                </svg>
                <span data-i18n="contact.fieldSubmit">{t.contact.fieldSubmit}</span>
              </button>
              <p class="form-disclaimer" data-i18n="contact.formDisclaimer">{t.contact.formDisclaimer}</p>
            </div>
          </form>

          <div id="form-success" class="form-success" hidden aria-live="polite">
            <div class="form-success__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <p>Su mensaje ha sido enviado. Nos pondremos en contacto con usted a la brevedad.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success') as HTMLElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name    = (form.elements.namedItem('name')    as HTMLInputElement).value.trim();
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
    const org     = (form.elements.namedItem('org')     as HTMLInputElement).value.trim();
    const subject = (form.elements.namedItem('subject') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    const lines = [
      `Nombre: ${name}`,
      `Correo: ${email}`,
      org ? `Organización: ${org}` : null,
      '',
      message,
    ].filter(l => l !== null).join('%0A');

    window.location.href = `mailto:contacto@hayya-system.com?subject=${encodeURIComponent(subject || 'Consulta desde sitio web')}&body=${lines}`;

    if (successMsg && form) {
      form.hidden = true;
      successMsg.hidden = false;
    }
  });
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .contact-aside {
    position: sticky;
    top: calc(68px + var(--space-8));
  }

  .contact-block__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-steel);
    letter-spacing: -0.015em;
    margin-bottom: var(--space-3);
  }

  .contact-block__text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .contact-email-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-5);
    background: var(--color-navy);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.06);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .contact-email-card:hover {
    border-color: rgba(200, 32, 43, 0.35);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .contact-email-card__icon {
    width: 40px;
    height: 40px;
    background: rgba(200, 32, 43, 0.14);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-light);
    flex-shrink: 0;
  }

  .contact-email-card__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }

  .contact-email-card__label {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--font-weight-semibold);
  }

  .contact-email-card__value {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact-email-card__arrow {
    color: rgba(255,255,255,0.25);
    flex-shrink: 0;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .contact-email-card:hover .contact-email-card__arrow {
    color: var(--color-primary-light);
    transform: translateX(3px);
  }

  .contact-response-note {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  .contact-aside__divider {
    width: 100%;
    height: 1px;
    background: var(--color-border);
    margin-block: var(--space-8);
  }

  .contact-aside__note-title {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-steel);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }

  .contact-aside__topics {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }

  .contact-aside__topics li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .contact-aside__topics li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-10);
  }

  .contact-form {
    margin-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-steel);
    letter-spacing: -0.005em;
  }

  .form-required { color: var(--color-primary); margin-left: 2px; }

  .form-input,
  .form-textarea {
    padding: 0.6875rem var(--space-4);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-neutral-50);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }

  .form-input::placeholder,
  .form-textarea::placeholder { color: var(--color-text-light); }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(200, 32, 43, 0.1);
    background: var(--color-white);
  }

  .form-textarea { resize: vertical; min-height: 128px; }

  .form-footer {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  .form-disclaimer {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    margin: 0;
    line-height: var(--leading-relaxed);
    max-width: 36ch;
  }

  .form-success {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background: rgba(22, 101, 52, 0.05);
    border: 1px solid rgba(22, 101, 52, 0.18);
    border-radius: var(--radius-lg);
    margin-top: var(--space-6);
  }

  .form-success__icon {
    width: 36px;
    height: 36px;
    background: rgba(22, 101, 52, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #166534;
    flex-shrink: 0;
  }

  .form-success p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: #166534;
    align-self: center;
  }

  @media (max-width: 960px) {
    .contact-layout { grid-template-columns: 1fr; gap: var(--space-10); }
    .contact-aside { position: static; }
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: var(--space-6); }
    .form-footer { flex-direction: column; align-items: flex-start; gap: var(--space-4); }
  }
</style>
