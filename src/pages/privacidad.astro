---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/index';

const t = getTranslations('es');
---

<Layout title={t.privacy.pageTitle} currentPath="/privacidad">

  <section class="page-hero">
    <div class="container">
      <span class="page-hero__label" data-i18n="privacy.pageLabel">{t.privacy.pageLabel}</span>
      <h1 class="page-hero__title" data-i18n="privacy.pageTitle">{t.privacy.pageTitle}</h1>
      <p class="page-hero__lead" data-i18n="privacy.pageLead">{t.privacy.pageLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="privacy-wrap">

        <div class="privacy-meta">
          <p class="privacy-updated" data-i18n="privacy.lastUpdated">{t.privacy.lastUpdated}</p>
          <p class="privacy-intro">Este documento describe las prácticas de privacidad de Hayya System. Si tiene preguntas, contáctenos en <a href={`mailto:${t.footer.email}`} class="privacy-link">{t.footer.email}</a>.</p>
        </div>

        <div class="privacy-body">
          <nav class="privacy-toc" aria-label="Índice de secciones">
            <p class="privacy-toc__title">Contenido</p>
            <ol class="privacy-toc__list">
              {t.privacy.sections.map((section, i) => (
                <li>
                  <a href={`#section-${i}`} class="privacy-toc__link">
                    {section.title}
                  </a>
                </li>
              ))}
            </ol>
          </nav>

          <div class="privacy-sections" data-i18n-privacy-sections>
            {t.privacy.sections.map((section, i) => (
              <div class="privacy-section" id={`section-${i}`} data-privacy-section>
                <h2 class="privacy-section__title" data-privacy-section-title>{section.title}</h2>
                <p class="privacy-section__text" data-privacy-section-text>{section.text}</p>
              </div>
            ))}

            <div class="privacy-contact-box">
              <div class="privacy-contact-box__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <p>Para ejercer sus derechos o consultar sobre esta política, escriba a <a href={`mailto:${t.footer.email}?subject=Derechos%20de%20datos%20personales`} class="privacy-link">{t.footer.email}</a> con el asunto <strong>"Derechos de datos personales"</strong>.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .privacy-wrap {
    max-width: 860px;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .privacy-meta {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .privacy-updated {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .privacy-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 65ch;
  }

  .privacy-link {
    color: var(--color-primary);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }
  .privacy-link:hover { text-decoration: underline; }

  /* Layout */
  .privacy-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Table of contents */
  .privacy-toc {
    position: sticky;
    top: calc(68px + var(--space-8));
  }

  .privacy-toc__title {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .privacy-toc__list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    list-style: none;
    padding: 0;
    counter-reset: none;
  }

  .privacy-toc__link {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: 0.3125rem 0.625rem;
    border-radius: var(--radius-xs);
    text-decoration: none;
    transition: all var(--transition-fast);
    border-left: 2px solid transparent;
    line-height: var(--leading-snug);
  }

  .privacy-toc__link:hover {
    color: var(--color-steel);
    background: var(--color-neutral-50);
    border-left-color: var(--color-primary);
  }

  /* Sections */
  .privacy-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .privacy-section {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border-subtle);
    scroll-margin-top: calc(68px + var(--space-8));
  }

  .privacy-section:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
  }

  .privacy-section__title {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-steel);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }

  .privacy-section__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 68ch;
  }

  /* Contact box */
  .privacy-contact-box {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-neutral-50);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-top: var(--space-4);
  }

  .privacy-contact-box__icon {
    width: 38px;
    height: 38px;
    background: rgba(200, 32, 43, 0.07);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .privacy-contact-box p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
    align-self: center;
  }

  .privacy-contact-box strong { color: var(--color-steel); }

  @media (max-width: 860px) {
    .privacy-body { grid-template-columns: 1fr; gap: var(--space-8); }
    .privacy-toc { position: static; }
  }
</style>
