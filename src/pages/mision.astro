---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/index';

const t = getTranslations('es');
const paragraphs = t.mission.body.split('\n\n').filter(Boolean);
---

<Layout title={t.mission.pageTitle} currentPath="/mision">

  <section class="page-hero">
    <div class="container">
      <span class="page-hero__label" data-i18n="mission.pageLabel">{t.mission.pageLabel}</span>
      <h1 class="page-hero__title" data-i18n="mission.pageTitle">{t.mission.pageTitle}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="statement-layout">
        <div class="statement-quote">
          <blockquote>
            <p class="quote__text" data-i18n="mission.statement">{t.mission.statement}</p>
          </blockquote>
        </div>
        <div class="statement-body" data-i18n-paras="mission.body">
          {paragraphs.map(p => <p class="statement-para">{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container container--narrow">
      <div class="page-nav">
        <a href="/vision" class="page-nav__link">
          <span class="page-nav__dir">Siguiente</span>
          <span class="page-nav__name" data-i18n="nav.vision">{t.nav.vision}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .statement-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
    max-width: 1000px;
  }

  .statement-quote {
    position: sticky;
    top: calc(72px + 2rem);
  }

  .statement-quote blockquote {
    margin: 0;
    border-left: 4px solid var(--color-primary);
    padding-left: var(--space-8);
  }

  .quote__text {
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    font-weight: var(--font-weight-semibold);
    color: var(--color-steel);
    line-height: var(--leading-snug);
    font-style: italic;
  }

  .statement-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .statement-para {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .page-nav { display: flex; justify-content: flex-end; }

  .page-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-white);
    color: var(--color-steel);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .page-nav__link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    transform: translateX(4px);
  }

  .page-nav__dir {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
  }

  .page-nav__name {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    display: block;
  }

  @media (max-width: 768px) {
    .statement-layout { grid-template-columns: 1fr; gap: var(--space-10); }
    .statement-quote { position: static; }
    .page-nav { justify-content: flex-start; }
  }
</style>
