---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/index';

const t = getTranslations('es');
---

<Layout title={t.careers.pageTitle} currentPath="/empleos">

  <section class="page-hero">
    <div class="container">
      <span class="page-hero__label" data-i18n="careers.pageLabel">{t.careers.pageLabel}</span>
      <h1 class="page-hero__title" data-i18n="careers.pageTitle">{t.careers.pageTitle}</h1>
      <p class="page-hero__lead" data-i18n="careers.pageLead">{t.careers.pageLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="careers-wrap">

        <div class="careers-intro">
          <p class="careers-intro__text" data-i18n="careers.intro">{t.careers.intro}</p>
        </div>

        <div class="careers-block">
          <h2 class="careers-block__title" data-i18n="careers.lookingForTitle">{t.careers.lookingForTitle}</h2>
          <p class="careers-block__text" data-i18n="careers.lookingForText">{t.careers.lookingForText}</p>
        </div>

        <div class="careers-block">
          <h2 class="careers-block__title">Áreas de interés</h2>
          <ul class="areas-grid" role="list" data-i18n-list="careers.areas">
            {t.careers.areas.map(area => (
              <li class="area-item" data-i18n-list-item>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span data-i18n-list-text>{area}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="careers-block">
          <h2 class="careers-block__title" data-i18n="careers.howToApplyTitle">{t.careers.howToApplyTitle}</h2>
          <p class="careers-block__text" data-i18n="careers.howToApplyText">{t.careers.howToApplyText}</p>
          <a
            href={`mailto:${t.footer.email}?subject=Perfil%20profesional`}
            class="btn btn--primary careers-cta-btn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            {t.footer.email}
          </a>
          <p class="careers-note">Asunto sugerido: "Perfil profesional — [área de especialización]"</p>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .careers-wrap { max-width: 860px; display: flex; flex-direction: column; gap: var(--space-10); }

  .careers-intro {
    padding: var(--space-8) var(--space-10);
    background: var(--color-navy);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-primary);
  }

  .careers-intro__text {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.72);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .careers-block {
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .careers-block:last-child { border-bottom: none; padding-bottom: 0; }

  .careers-block__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-steel);
    margin-bottom: var(--space-4);
  }

  .careers-block__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 65ch;
  }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
  }

  .area-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-neutral-50);
  }

  .area-item svg { color: var(--color-primary); flex-shrink: 0; }

  .careers-cta-btn { margin-top: var(--space-6); }

  .careers-note {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .areas-grid { grid-template-columns: 1fr; }
    .careers-intro { padding: var(--space-6); }
  }
</style>
